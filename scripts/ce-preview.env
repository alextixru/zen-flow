# Окружение для локального CE-превью (dist-бутстрап API).
# Подхватывается scripts/start-ce.sh через `source`, поэтому $HOME раскрывается.
# ВНИМАНИЕ: значения ниже — демонстрационные, НЕ использовать в проде.

AP_CONTAINER_TYPE=APP
AP_PORT=8080
AP_ENVIRONMENT=prod
AP_EDITION=ce
AP_DB_TYPE=PGLITE
AP_REDIS_TYPE=MEMORY
AP_EXECUTION_MODE=UNSANDBOXED
AP_CONFIG_PATH=$HOME/.activepieces
AP_FRONTEND_URL=http://localhost:8080
AP_TELEMETRY_ENABLED=false

# Закреплённые ключи, чтобы сессия в браузере переживала перезапуски.
AP_JWT_SECRET=zenflow_demo_jwt_secret_do_not_use_in_prod_0123456789
AP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
