# Скопировать в .env и заполнить. Файл .env — вне git.

# Postgres EE-стенда форка (dev-stand.sh)
AP_POSTGRES_URL=

# Порт, на котором слушает сам мост (path-роутер шлёт сюда /bridge/*)
PORT=8083

# Публичный https-URL форка — стабильный SSH-туннель (dev-stand.sh), не меняется
FORK_URL=https://amoai-dev.dzen.team

# Публичный https-URL моста (тот же туннель, path-роутер /bridge/* -> :8083)
BRIDGE_PUBLIC_URL=https://amoai-dev.dzen.team/bridge

# Embedding signing key (Platform Settings -> Security -> Embedding)
SIGNING_KEY_ID=
SIGNING_KEY_PATH=data/signing-key.pem

# Файл SQLite моста (путь относительно корня bridge/)
DB_PATH=data/bridge.db

# Platform API key форка (sk-…) для SERVICE-эндпоинтов (allowed-embed-origins).
# Выпуск: POST /api/v1/api-keys под platform-админом (или UI Platform Admin -> API Keys).
FORK_API_KEY=
